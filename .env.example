# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret
DJANGO_DEBUG=True

# Database (leave blank to use SQLite in development)
# Production: use a PostgreSQL connection string from Neon, Supabase, etc.
# Example: postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Additional allowed hosts (comma-separated)
# Production: exploringu.com,www.exploringu.com
ALLOWED_HOSTS=

# Additional CORS origins (comma-separated)
# Production: https://exploringu.com,https://www.exploringu.com
CORS_ALLOWED_ORIGINS=

# SSL redirect (set to false if behind a load balancer that already handles SSL)
SECURE_SSL_REDIRECT=true

# Optional: Google Gemini for dashboard insights (server-side only)
# GEMINI_API_KEY=
# Optional model override (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview
